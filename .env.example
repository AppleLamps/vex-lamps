# Provider selection
# Options: "gemini" (default) | "claude"
PROVIDER=gemini

# Gemini (Google AI Studio)
# `gemma-4-31b-it` works well as the local-first default for planning and Manim scene generation.
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemma-4-31b-it

# Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-5

# Stock footage
PEXELS_API_KEY=your_pexels_api_key_here

# Shared runtime
AGENT_PROJECTS_DIR=~/.video-agent/projects/
FFMPEG_PATH=ffmpeg
BLENDER_PATH=blender
WHISPER_MODEL=base
GEMINI_TRANSCRIPT_MAX_INLINE_MB=100
GEMINI_TRANSCRIPT_MAX_INLINE_DURATION_SEC=90
VEX_WEB_MAX_UPLOAD_MB=4096
GENAI_TIMEOUT_SEC=90
ANTHROPIC_TIMEOUT_SEC=90
MANIM_PREVIEW_TIMEOUT_SEC=75
MANIM_FINAL_TIMEOUT_SEC=240
FFMPEG_COMMAND_TIMEOUT_SEC=900
FFMPEG_EXPORT_TIMEOUT_SEC=3600
BLENDER_RENDER_TIMEOUT_SEC=600
LLM_REQUEST_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY_SEC=1.5
